<Page x:Class="WpfLayoutUIOefenblad.Exercises.TabControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="TabControl">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="#EEFDEF" BorderBrush="#6B6CB0" BorderThickness="1" Padding="12" Margin="20">
            <!-- TODO: PAS HIERONDER DE XAML AAN -->
            <TabControl SelectedIndex="2" Margin="10.5">
                <TabItem Header="Account">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Label Margin="10" HorizontalAlignment="Left" VerticalContentAlignment="Center" >E-Mail:</Label>
                        <TextBox Grid.Column="1" Margin="15"/>

                        <Label Grid.Column="0" Grid.Row="1" Margin="10" HorizontalAlignment="Left" VerticalContentAlignment="Center" >Wachtwoord:</Label>
                        <TextBox Grid.Column="1" Grid.Row="1" Margin="15"/>

                        <TextBox Grid.Column="2" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" HorizontalContentAlignment="center" 
                                 Background="LightGray" BorderBrush="Gray" Margin="5,0,15,0">Wijzigen</TextBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Voorkeuren" Margin="0" Padding="10,5">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Content="Nieuwbrief ontvangern" Margin="5"/>
                        <CheckBox Content="Donkere modus" Margin="5"/>
                        <CheckBox Content="Meldingen toestaan" Margin="5"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Over" Margin="0" Padding="10,5">
                    <TextBlock Margin="10">
                        Dit is een voorbeeldapplicatie om Tabcontrol te oefenen? Gebruik tabs om instellingen <Run Text="logisch te groeperen" FontWeight="Bold"/> en het scherm overzichtelijk te houden.
                        <LineBreak/>
                        <LineBreak/>
                        Mohamed Reda Ben Taouet, 2026
                    </TextBlock>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>
